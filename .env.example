# ============================================================
# presales 환경변수 예시 (개발자 온보딩용)
# 복사 방법: cp .env.example .env.local  →  실제 값 채우기
# 실제 값은 절대 이 파일에 커밋하지 마세요.
# ============================================================

# ────────────────────────────────────────────────
# Supabase (필수)
# https://supabase.com → Settings → API
# ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버사이드 전용 — 절대 NEXT_PUBLIC_ 접두사 사용 금지
# Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────
# 사이트 URL
# 로컬: http://localhost:3000  |  프로덕션: https://presales.co.kr
# ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ────────────────────────────────────────────────
# Google Analytics 4 (선택)
# 없으면 GoogleAnalytics 컴포넌트가 자동으로 비활성화됨
# GA4 → 관리 → 데이터 스트림 → 측정 ID (형식: G-XXXXXXXXXX)
# ────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ────────────────────────────────────────────────
# Microsoft Clarity (선택)
# Clarity → Project settings → Setup → Project ID
# 비어 있으면 코드 기본값 또는 비활성 설정에 따름
# ────────────────────────────────────────────────
NEXT_PUBLIC_CLARITY_PROJECT_ID=wkkq5ht3nh

# ────────────────────────────────────────────────
# Kakao JavaScript SDK (선택 — 상품 상세 카카오톡 공유 / 카카오톡 채널 상담)
# Kakao Developers → 앱 → 플랫폼 키 → JavaScript 키
# 운영 도메인은 Kakao Developers의 JavaScript SDK 도메인/제품 링크 웹 도메인에도 등록
# 채널 상담을 쓰려면 Kakao Developers 앱에 카카오톡 채널을 연결하고 채널 홈 URL의 공개 ID를 입력
# ────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
NEXT_PUBLIC_KAKAO_CHANNEL_PUBLIC_ID=

# ────────────────────────────────────────────────
# 토스페이먼츠 결제 (PG 연동 시 필수)
# https://developers.tosspayments.com → 내 개발정보
# 개발: test_ck_ / test_sk_  |  운영: live_ck_ / live_sk_
# ────────────────────────────────────────────────
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ────────────────────────────────────────────────
# 이메일 발송 SMTP (메일플러그)
# 주문확인 / 컨설팅 접수 이메일 발송에 사용
# Gmail SMTP 사용 금지 — 메일플러그만 사용
# ────────────────────────────────────────────────
SMTP_HOST=smtp.mailplug.co.kr
SMTP_PORT=465
SMTP_USER=help@amarans.co.kr
SMTP_PASS=your-smtp-password
POP3_HOST=pop3.mailplug.co.kr
POP3_PORT=995
POP3_SSL=true

# ────────────────────────────────────────────────
# 무통장 입금 계좌 (선택)
# 회사 수금 계좌. 미설정 시 코드 기본값 사용
# 계좌 변경 시 여기/Vercel 환경변수만 수정하면 됨 (재배포 1번)
# ────────────────────────────────────────────────
BANK_NAME=기업은행
BANK_ACCOUNT_NUMBER=394-056559-01-013
BANK_HOLDER=(주)아마란스

# ────────────────────────────────────────────────
# 관리자 이메일
# ADMIN_EMAIL: 기존 컨설팅/일반 알림, ADMIN_ALERT_EMAIL: 주문/입금/신규회원 운영 알림
# ────────────────────────────────────────────────
ADMIN_EMAIL=help@amarans.co.kr
ADMIN_ALERT_EMAIL=hojin@amarans.co.kr

# ────────────────────────────────────────────────
# Telegram MCP (선택 — Codex 로컬 알림/지시 확인용)
# BotFather 에서 봇 토큰 발급 후 봇에게 /start 를 보낸 뒤 chat_id 확인
# 실제 값은 .env.local 또는 OS 환경변수에만 입력
# ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ────────────────────────────────────────────────
# Upstash Redis (선택 — 분산 rate-limit)
# Vercel 멀티 인스턴스에서 rate-limit 을 일관되게 적용
# https://console.upstash.com → Create Database (무료) → REST 탭
# 미설정 시 인메모리로 자동 fallback (개발/단일 인스턴스 OK)
# ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXXXXXXXXXXXXXXXXXXXX

# ────────────────────────────────────────────────
# 모닝브리프 (별도 Supabase 프로젝트, 2026-04-26 신설)
# 마스터 명단 — presales / SPC / maru AI 사이트가 공유.
# ynvirceyybekzyqbzbxz
# ────────────────────────────────────────────────
MORNING_BRIEF_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
MORNING_BRIEF_SUPABASE_ANON_KEY=eyJ...
MORNING_BRIEF_SUPABASE_SERVICE_KEY=eyJ...   # service_role, 서버 전용
MORNING_BRIEF_SOURCE=presales                # 'presales' | 'spc' | 'maruai'
MB_CRON_SECRET=                              # 모닝브리프 Cron 전용 (presales CRON_SECRET 과 분리)
ANTHROPIC_API_KEY=                            # Claude Haiku dedup 전용 (메모리 feedback_no_api_costs 예외)
CLAUDE_DEDUP_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=                              # AI RFP 분석 전용, 서버 전용
OPENAI_RFP_MODEL=gpt-5.5
MAIL_FROM_NAME=프리세일즈
MAIL_FROM_EMAIL=help@amarans.co.kr
