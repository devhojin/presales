# ============================================================
# presales 환경변수 예시 (개발자 온보딩용)
# 복사 방법: cp .env.example .env.local  →  실제 값 채우기
# 실제 값은 절대 이 파일에 커밋하지 마세요.
# ============================================================

# ────────────────────────────────────────────────
# Supabase (필수)
# https://supabase.com → Settings → API
# ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버사이드 전용 — 절대 NEXT_PUBLIC_ 접두사 사용 금지
# Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────
# 사이트 URL
# 로컬: http://localhost:3000  |  프로덕션: https://presales.co.kr
# ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ────────────────────────────────────────────────
# Google Analytics 4 (선택)
# 없으면 GoogleAnalytics 컴포넌트가 자동으로 비활성화됨
# GA4 → 관리 → 데이터 스트림 → 측정 ID (형식: G-XXXXXXXXXX)
# ────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ────────────────────────────────────────────────
# 토스페이먼츠 결제 (PG 연동 시 필수)
# https://developers.tosspayments.com → 내 개발정보
# 개발: test_ck_ / test_sk_  |  운영: live_ck_ / live_sk_
# ────────────────────────────────────────────────
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ────────────────────────────────────────────────
# 이메일 발송 SMTP (메일플러그)
# 주문확인 / 컨설팅 접수 이메일 발송에 사용
# Gmail SMTP 사용 금지 — 메일플러그만 사용
# ────────────────────────────────────────────────
SMTP_HOST=mail.mailplug.co.kr
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-password
