# Codex / MCP runtime variables
# Copy the variables you need into your shell profile or secret manager.

# GitHub MCP
# Required for private repo access in github-presales MCP.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Supabase MCP
# Create a personal access token in Supabase and scope it to the organization/project you use.
SUPABASE_ACCESS_TOKEN=

# Context7 MCP
# Optional. Context7 works without this for many cases, but an API key is recommended for stable usage.
CONTEXT7_API_KEY=

# Telegram MCP
# Optional. Used by telegram-presales MCP for local Codex notifications and instruction checks.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
